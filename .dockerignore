# Ignore Docker-specific files themselves
Dockerfile*
.dockerignore

# Ignore editor-specific files
.vscode/
.idea/
*.swp

# Ignore the version control system
.git
.gitignore

# Ignore data
dalitz_toy_data_*

# Never bake user-data into the image; supply it via a bind-mount at runtime.
# See ERSAP_USER_DATA in Dockerfile.cli and entrypoint.sh.
ersap-data/

.claude

build
